{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/index.ts",
    "src/bootstrap/**/*",
    "src/shared/**/*",
    "src/main/**/*"
  ],
  "exclude": ["src/main/index.ts"],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    // Dead-code gates at type-check time (see tsconfig.node.json).
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowUnreachableCode": false,
    // Guard every array/record access (see tsconfig.node.json).
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@offgrid/core/*": [
        "./src/*"
      ],
      "@offgrid/pro/*": [
        "./src/bootstrap/proStub.ts"
      ]
    }
  }
}
