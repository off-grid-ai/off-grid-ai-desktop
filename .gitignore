node_modules
dist
out
.DS_Store
.eslintcache
*.log*

# Google OAuth client (secret) — do not commit
src/main/google-client.ts

# Local reference component library (not part of the app build)
component-library-animations/

# Bundled MLX (mflux) Python env — large, rebuilt via scripts/build-mflux-env.sh
resources/bin/mflux/

# Off Grid SD-GGUF conversion build dir
build-sd-gguf/

# Swift build artifacts (embedded repos)
electron/coreml-sd/.build/
electron/coreml-sd/.swiftpm/
electron/accessibility/ocr

# Bundled runtime binaries live in Git LFS (see .gitattributes) so CI can bundle
# them. Only the heavy optional runtimes we don't ship are excluded.
resources/bin/coreml-sd/
resources/bin/mflux/
# Parakeet STT runtime — CI-staged via scripts/fetch-parakeet.sh (like mflux/coreml-sd),
# not committed. Devs stage it locally with the same script.
resources/bin/parakeet/
# Gateway probe scratch output
.gateway-probe/
# TS build cache
*.tsbuildinfo

# Private pro features — separate repo, added as a git submodule once the remote
# exists. Ignored for now so the open repo never tracks pro source.
/pro/

# Vendored @offgrid packages ship their built dist
!packages/*/dist/
!packages/*/dist/**

# Local env (telemetry/keys) — never commit
.env
.env.local
test-results/

# Marketing material (dev.to drafts, emails, assets) — publishing, not app code
/marketing/
scripts/dictation-hotkey/dictation-hotkey

# Local demo profile — synthetic-data run target for `npm run demo` (never real userData)
.demo-profile/

# Local test/runtime profile — generated dummy models + gateway logs, never real userData
.offgrid/

# Test coverage output
coverage/
swift-tests/**/.build/

# Off Grid AI Pro early-bird campaign (customer PII + send tooling - do not commit)
marketing/emails/pro-earlybird/
