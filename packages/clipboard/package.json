{
  "name": "@offgrid/clipboard",
  "version": "0.0.1",
  "private": true,
  "description": "Off Grid shared clipboard: cross-platform clipboard capture + history engine, embeddable in desktop and mobile. Absorbed from copyclip (MIT).",
  "license": "AGPL-3.0-only",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./electron": {
      "types": "./dist/adapters/electron.d.ts",
      "import": "./dist/adapters/electron.mjs",
      "require": "./dist/adapters/electron.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/adapters/electron.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/adapters/electron.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  }
}
